# Custom OpenClaw image — extends official image with exec tool support
# Grants the node user access to python3, pip3, curl, wget, jq, bash
# so agents can autonomously execute scripts without Permission denied errors.
ARG BASE_IMAGE=ghcr.io/openclaw/openclaw:latest
FROM ${BASE_IMAGE}

USER root

# Try apk (Alpine) first, fall back to apt-get (Debian/Ubuntu)
RUN apk add --no-cache \
        python3 \
        py3-pip \
        curl \
        wget \
        jq \
        bash \
    2>/dev/null \
    || (apt-get update -qq \
        && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3 python3-pip python3-venv curl wget jq bash \
        && rm -rf /var/lib/apt/lists/*) \
    ; true

# Create canonical symlinks and ensure world-executable permissions
RUN PYTHON_BIN="$(which python3 2>/dev/null || echo '')" && \
    PIP_BIN="$(which pip3 2>/dev/null || echo '')" && \
    [ -n "$PYTHON_BIN" ] && ln -sf "$PYTHON_BIN" /usr/local/bin/python || true && \
    [ -n "$PIP_BIN" ]    && ln -sf "$PIP_BIN"    /usr/local/bin/pip    || true && \
    chmod -R o+rx /usr/bin/python* /usr/local/bin/python* 2>/dev/null || true && \
    chmod -R o+rx /usr/bin/pip*    /usr/local/bin/pip*    2>/dev/null || true && \
    chmod -R o+rx /usr/bin/curl    /usr/bin/wget          2>/dev/null || true

USER node
