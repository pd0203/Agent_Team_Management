{
  "logging": {
    "level": "info",
    "file": "/shared/logs/openclaw.log",
    "consoleLevel": "info",
    "consoleStyle": "json",
    "redactSensitive": "tools"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "${LLM_FLASH_MODEL}",
        "fallbacks": []
      },
      "sandbox": {
        "mode": "off"
      }
    },
    "list": [
      {
        "id": "chief-secretary",
        "default": true,
        "name": "비서실장",
        "workspace": "/home/node/.openclaw/workspace/chief-secretary",
        "model": {
          "primary": "${LLM_FLASH_MODEL}",
          "fallbacks": []
        },
        "identity": {
          "name": "비서실장",
          "emoji": "🤵"
        },
        "subagents": {
          "allowAgents": [
            "chief-secretary-pro",
            "planning-pm",
            "finance-manager",
            "asset-manager"
          ]
        }
      },
      {
        "id": "chief-secretary-pro",
        "name": "비서실장-Pro",
        "workspace": "/home/node/.openclaw/workspace/chief-secretary-pro",
        "model": {
          "primary": "${LLM_PRO_MODEL}",
          "fallbacks": [
            "${LLM_FLASH_MODEL}"
          ]
        },
        "identity": {
          "name": "비서실장-Pro",
          "emoji": "🧠"
        }
      },
      {
        "id": "planning-pm",
        "name": "기획PM",
        "workspace": "/home/node/.openclaw/workspace/planning-pm",
        "model": {
          "primary": "${LLM_PRO_MODEL}",
          "fallbacks": [
            "${LLM_FLASH_MODEL}"
          ]
        },
        "identity": {
          "name": "기획PM",
          "emoji": "📋"
        }
      },
      {
        "id": "finance-manager",
        "name": "재무담당",
        "workspace": "/home/node/.openclaw/workspace/finance-manager",
        "model": {
          "primary": "${LLM_PRO_MODEL}",
          "fallbacks": [
            "${LLM_FLASH_MODEL}"
          ]
        },
        "identity": {
          "name": "재무담당",
          "emoji": "💰"
        }
      },
      {
        "id": "asset-manager",
        "name": "자산관리사",
        "workspace": "/home/node/.openclaw/workspace/asset-manager",
        "model": {
          "primary": "${LLM_PRO_MODEL}",
          "fallbacks": [
            "${LLM_FLASH_MODEL}"
          ]
        },
        "identity": {
          "name": "자산관리사",
          "emoji": "📈"
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "enabled": false
      }
    }
  },
  "bindings": [
    {
      "agentId": "chief-secretary",
      "match": {
        "channel": "telegram"
      }
    }
  ],
  "messages": {
    "queue": {
      "mode": "collect",
      "debounceMs": 800,
      "cap": 10
    },
    "ackReaction": "👀",
    "ackReactionScope": "all"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "session": {
    "scope": "per-sender",
    "dmScope": "per-channel-peer"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [
        "${CEO_TELEGRAM_ID}"
      ],
      "groupPolicy": "allowlist",
      "historyLimit": 20,
      "streamMode": "partial",
      "mediaMaxMb": 10
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.2.17",
    "lastTouchedAt": "2026-02-25T01:53:11.241Z"
  }
}
